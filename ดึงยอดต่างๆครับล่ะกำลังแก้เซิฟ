    // 11. GLOBAL KILL FEED (ป้ายวิ่งประกาศผลเซิร์ฟเวอร์)
    // =========================================
    async function fetchGlobalKillFeed() {
        try {
            // ยิง API ไปดึงข้อมูล 5 อันดับล่าสุดจาก Server
            const response = await fetch("https://game-server-vs0h.onrender.com/api/kill-feed");
            const resData = await response.json();

            // ถ้ามีข้อมูลส่งกลับมา
            if (resData.success && resData.data.length > 0) {
                let combinedText = "";
                
                // วนลูปเอา 5 รายการมาต่อกัน พร้อมใส่สีตกแต่งให้เข้าธีมเกม
                resData.data.forEach(item => {
                    combinedText += `
                        <span style="color:#ff2a2a;">🔥</span> 
                        [<span style="color:#00eaff;">${item.playerName}</span>] LV.${item.level} 
                        DEFEATED <span style="color:#ff9d00;">${item.monsterName}</span> 
EARNING <span style="color:#ffd700; font-weight:bold;">${item.reward} COINS!</span> 
                        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                    `;
                });

                const marqueeText = document.querySelector('.marquee-text');
                if (marqueeText) {
                    // ใส่ข้อความใหม่ลงไปในป้ายวิ่ง
                    marqueeText.innerHTML = combinedText;
                    
                    // บังคับรีเซ็ตแอนิเมชัน เพื่อให้ข้อความวิ่งต่อแบบเนียนๆ
                    marqueeText.style.animation = 'none';
                    marqueeText.offsetHeight; // Trigger Reflow
                    // ปรับเวลาวิ่งเป็น 25 วิ ให้ความเร็วพอดีอ่านทัน
                    marqueeText.style.animation = 'scroll-left 25s linear infinite'; 
                }
            }
        } catch (err) {
            console.error("Kill Feed Sync Error:", err);
            // ถ้าเน็ตหลุดหรือเซิร์ฟเวอร์ตอบช้า จะไม่โชว์แจ้งเตือนกวนใจผู้เล่น ปล่อยให้ป้ายเดิมวิ่งต่อไป
        }
    }

    // 📌 ดึงข้อมูลทันที 1 ครั้ง ตอนเปิดโหลดเข้าเกม
    setTimeout(fetchGlobalKillFeed, 2000); // หน่วงเวลา 2 วินาทีให้รอล็อกอินเสร็จก่อน

    // 📌 ดึงข้อมูลใหม่เงียบๆ (Background Sync) ทุกๆ 20 วินาที
    setInterval(fetchGlobalKillFeed, 20000);

