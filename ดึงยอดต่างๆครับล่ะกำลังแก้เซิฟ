            return gameAlert("ERROR", `⛔ MINIMUM AMOUNT IS ${MIN_BUY_WLD} WLD`);

        if (!window.MiniKit?.isInstalled())
            return gameAlert("ERROR", "⛔ PLEASE OPEN IN WORLD APP");

        btn.disabled = true;
        btn.innerText = "PROCESSING PAY...";

        try {
            const coinsToReceive = Math.floor(amountWLD * BUY_RATE);
            const amountInWei = BigInt(Math.floor(amountWLD * 1000000)) * 1000000000000n;
            const refOrder = "order_" + Date.now();

            const result = await window.MiniKit.commandsAsync.pay({
                reference: refOrder,
                to: RECEIVER,
                tokens: [{
                    symbol: "WLD",
                    token_amount: amountInWei.toString()
                }],
                description: `Buy ${coinsToReceive} COINS`
            });

            if (result?.finalPayload?.status !== "success") {
                throw new Error("TRANSACTION CANCELLED");
            }

            // 🌟 เมื่อจ่ายผ่าน World App แล้ว ยิงบอก Server ให้เพิ่มเหรียญ
            btn.innerText = "SYNCING SERVER...";
            
            try {
                const syncRes = await fetch("https://game-server-vs0h.onrender.com/api/buy-coins", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        userId: window.REAL_USER_ID,
                        amountBought: coinsToReceive,
                        reference: refOrder
                    })
                });
                
                const syncData = await syncRes.json();
                
                if (syncData.success && syncData.newBalance !== undefined) {
                    playerCOIN = syncData.newBalance; // ดึงยอดล่าสุดจาก Server ชัวร์ที่สุด
                } else {
                    playerCOIN += coinsToReceive; // Fallback ถ้ายิงผ่านแต่ไม่ตอบกลับ newBalance
                }
            } catch (syncErr) {
                console.warn("เซิร์ฟเวอร์ตอบสนองล่าช้า แต่เติมเงินสำเร็จแล้ว", syncErr);
                playerCOIN += coinsToReceive; // Fallback กันพลาดถ้า Server ล่มชั่วขณะ
            }

            if (typeof updateBalance === "function") updateBalance();

            overlay.remove();
            
            // ✅ ใช้ gameAlert แจ้งเตือนซื้อสำเร็จ
            gameAlert("PURCHASE SUCCESS", `SUCCESSFULLY RECEIVED <span style="color:#ffd700; font-size:1.2rem;">${coinsToReceive} COINS</span>!`);

        } catch (err) {
            console.error("Buy Error:", err);
            if (!err.message?.includes("ยกเลิก"))
                gameAlert("ERROR", "❌ ERROR OCCURRED: " + (err.message || err));
        } finally {
            btn.disabled = false;
            btn.innerText = "CONFIRM BUY";
        }
    };


