    function flashDamage(who, amount) { 
    if(amount <= 0) return; 
    const txt = document.getElementById(who === 'e' ? 'eDmgText' : 'pDmgText'); 
    if(!txt) return;

    txt.textContent = "-" + amount; 
    playSfx('hit'); 

    // เอฟเฟกต์ตัวเลขลอยและขยาย
    gsap.fromTo(txt, 
        { display: 'block', opacity: 0, scale: 0.5, y: 0 }, 
        { opacity: 1, scale: 2, y: -50, duration: 0.5, ease: "back.out(2)", onComplete: () => {
            gsap.to(txt, { opacity: 0, delay: 0.5, duration: 0.3 });
        }}
    );

    // เอฟเฟกต์หน้าจอสั่น (Battle Area Shake)
    gsap.to('#battleArea', { x: 8, duration: 0.05, repeat: 5, yoyo: true });
}


