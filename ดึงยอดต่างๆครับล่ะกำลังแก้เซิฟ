         function slashEffect(who) {
    const targetId = who === 'e' ? 'bossImg' : 'playerHpText';
    const target = document.getElementById(targetId);
    if (!target) return;

    const rect = target.getBoundingClientRect();
    const slash = document.createElement('div');
    
    // ตั้งค่าเริ่มต้น: เป็นเส้นเล็กๆ และเอียง
    slash.style.cssText = `
        position: fixed;
        top: ${rect.top + (rect.height / 2)}px;
        left: ${rect.left + (rect.width / 2) - 150}px;
        width: 300px;
        height: 2px; /* เริ่มต้นด้วยเส้นบางๆ */
        background: #fff;
        box-shadow: 0 0 10px #00eaff;
        z-index: 20000;
        transform: rotate(-45deg) scaleX(0); /* เริ่มจากจุดศูนย์กลาง */
        pointer-events: none;
        border-radius: 10px;
    `;
    document.body.appendChild(slash);

    const tl = gsap.timeline({ onComplete: () => slash.remove() });
    
    // 1. ฟันฉับ: ยืดความยาวออกไปก่อน (ScaleX)
    tl.to(slash, { 
        scaleX: 1.2, 
        duration: 0.1, 
        ease: "power2.out" 
    })
    // 2. ระเบิดพลัง: ขยายความหนา (Height) และรัศมีแสง (Box-shadow)
    .to(slash, { 
        height: 20, // ขยายใหญ่ขึ้นตามโจทย์
        boxShadow: "0 0 30px #00eaff, 0 0 60px #fff",
        duration: 0.1,
        ease: "expo.out"
    })
    // 3. จางหาย: จางไปพร้อมกับหดตัว
    .to(slash, { 
        opacity: 0, 
        scaleY: 0, 
        duration: 0.3,
        ease: "power2.in"
    });

    // สั่นหน้าจอแรงๆ ตอนที่มันขยายใหญ่
    gsap.to('#battleArea', { x: 10, duration: 0.05, repeat: 4, yoyo: true });
}


