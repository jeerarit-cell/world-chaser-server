            return gameAlert("ERROR", `⛔ MINIMUM ${MIN_SELL} COINS`);

        if (typeof playerCOIN === "undefined" || playerCOIN < amountCoin)
            return gameAlert("ERROR", "⛔ NOT ENOUGH COINS!");

        if (!window.MiniKit?.isInstalled())
            return gameAlert("ERROR", "PLEASE OPEN IN WORLD APP");

        if (!window.REAL_USER_ID)
