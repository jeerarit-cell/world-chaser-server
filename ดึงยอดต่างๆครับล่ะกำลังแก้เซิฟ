            * 🔴🟠🟡🟢🔵🟣🟤⚪️⚫️<br>
            (Sign Message Only ❤)
        </p>
    `; 
    
    overlay.appendChild(box); 
    document.body.appendChild(overlay); 
    
    const input = document.getElementById('inpName'); 
    input.focus(); 

    // --- 2. LOGIC ปุ่มกด (หัวใจสำคัญ) ---
    const btn = document.getElementById('btnConfirmName');
    
    btn.onclick = async () => { 
        const newName = input.value.trim().toUpperCase(); 
        
        // --- Validation เช็คชื่อ ---
        if (!newName) return; 
        if (newName.length > 8) { alert("⛔ NAME TOO LONG! (MAX 8 CHARS)"); return; } 
        const regex = /^[A-Z0-9]+$/; // อนุญาตแค่ A-Z และ 0-9
        if (!regex.test(newName)) { alert("⛔ ALPHANUMERIC ONLY (A-Z, 0-9)"); return; } 

        // --- เริ่มกระบวนการผูกกระเป๋า ---
        try {
            btn.disabled = true;
            btn.innerText = "⏳️ WAIT...";
